# Environment configuration example file
# Copy this file as .env.dev, .env.test, .env.prod etc.

# Base URL configuration
BASE_URL=https://demo.myapp.com

# Test account configuration
TEST_USERNAME=admin
TEST_PASSWORD=password123

# Other user accounts
USER_USERNAME=testuser@example.com
USER_PASSWORD=testpass123

# Browser configuration
BROWSER_TIMEOUT=30000
SCREENSHOT_PATH=screenshots

# Report configuration
REPORT_PATH=reports
# Alternative environment variable for reports directory (used as fallback)
# REPORTS_DIR=reports
GENERATE_REPORT=true
REPORT_FORMAT=html
REPORT_STYLE=detailed